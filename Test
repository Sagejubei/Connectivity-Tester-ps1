# Set the error action preference
$ErrorActionPreference = "SilentlyContinue"

# Define variables
$server = "www.google.com"
$maxAttempts = 5
$successfulPing = $false

# Start the For loop
for ($attempt = 1; $attempt -le $maxAttempts; $attempt++) {
    # Calcualte timeout, increasing by 1 second each attempt
    $timeout = $attempt * 1000 # Convert to milliseconds
    Write-Host "Attempt $attempt with timeout $timeout ms"

    # Attempt to ping the server
    $result = Test-Connection -ComputerName $server -Count 1 -Timeout $timeout -ErrorAction SilentlyContinue

    # Check if the ping was successful
    if ($result) {
        $successfulPing = $true
        Write-Host "Success! Latency: $($result.Latency) ms" -ForegroundColor Green
        break # Exit the loop early if successful
    }
    else {
        Write-Host "Failed. Increasing timeout and retrying..." -ForegroundColor Yellow
    }
}

# FInal check after all attempts
if (-not $successfulPing) {
    Write-Host "All attempts failed. Unable to reach $server." -ForegroundColor Red
}

